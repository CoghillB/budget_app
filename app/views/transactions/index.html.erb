<% content_for :title, "Transactions · Budget App" %>

<div class="toolbar">
  <h1 class="page-title">Transactions</h1>
  <div>
    <%= link_to "New transaction", new_transaction_path, class: "btn" %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <% if @transactions.blank? %>
      <div class="empty-state">
        <p>No transactions yet.</p>
        <%= link_to "Create your first transaction", new_transaction_path, class: "btn" %>
      </div>
    <% else %>
      <div class="table-wrap">
        <table class="table" id="transactions">
          <thead>
            <tr>
              <th>Date</th>
              <th>Description</th>
              <th class="td-right">Amount</th>
              <th class="td-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% @transactions.each do |transaction| %>
              <tr>
                <td><%= transaction.respond_to?(:date) && transaction.date.present? ? l(transaction.date) : "—" %></td>
                <td>
                  <%= transaction.description %>
                </td>
                <td class="td-right">
                  <%= number_to_currency(transaction.amount, unit: "$", precision: 2) %>
                </td>
                <td class="td-right actions">
                  <%= link_to "Show", transaction, class: "btn secondary" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
